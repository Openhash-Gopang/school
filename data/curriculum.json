      "isced_level": "ISCED 0 (early childhood educational development)",
      "ib_programme": null,
      "piaget": "Sensorimotor",
      "approach": "Sensory play, attachment, motor development — no formal curriculum"
    },
    {
      "id": "S1",
      "label_en": "Pre-Primary",
      "label_ko": "유아기",
      "age_range": "3–5",
      "isced_level": "ISCED 0 (pre-primary education)",
      "ib_programme": "IB PYP (preparation)",
      "piaget": "Pre-operational",
      "approach": "Play-based learning, inquiry through senses, social-emotional foundation"
    },
    {
      "id": "S2",
      "label_en": "Lower Primary",
      "label_ko": "아동기 전기",
      "age_range": "6–8",
      "isced_level": "ISCED 1",
      "ib_programme": "IB PYP",
      "piaget": "Concrete operational (early)",
      "approach": "Story-based, concrete manipulatives, interdisciplinary inquiry"
    },
    {
      "id": "S3",
      "label_en": "Upper Primary",
      "label_ko": "아동기 후기",
      "age_range": "9–11",
      "isced_level": "ISCED 1",
      "ib_programme": "IB PYP",
      "piaget": "Concrete operational (late)",
      "approach": "Project-based learning, logical operations, community connection"
    },
    {
      "id": "S4",
      "label_en": "Lower Secondary",
      "label_ko": "청소년 전기",
      "age_range": "12–14",
      "isced_level": "ISCED 2",
      "ib_programme": "IB MYP (years 1–3)",
      "piaget": "Formal operational (emerging)",
      "approach": "Abstract reasoning begins, interdisciplinary units, service learning"
    },
    {
      "id": "S5",
      "label_en": "Upper Secondary",
      "label_ko": "청소년 후기",
      "age_range": "15–17",
      "isced_level": "ISCED 3",
      "ib_programme": "IB DP / MYP (years 4–5)",
      "piaget": "Formal operational",
      "approach": "Specialisation begins, extended essays, career exploration"
    },
    {
      "id": "S6",
      "label_en": "Post-Secondary / Undergraduate",
      "label_ko": "성인 초기",
      "age_range": "18–21",
      "isced_level": "ISCED 5–6",
      "ib_programme": "IB DP (completion) / University",
      "piaget": "Post-formal (contextual)",
      "approach": "Discipline depth, research methods, professional practice"
    },
    {
      "id": "S7",
      "label_en": "Graduate & Lifelong Learning",
      "label_ko": "성인·평생학습",
      "age_range": "22+",
      "isced_level": "ISCED 7–8 + ISCED 0021 Literacy/Adult",
      "ib_programme": null,
      "piaget": "Post-formal",
      "approach": "Research, specialisation, career change, re-skilling"
    }
  ],

