{
  "_meta": {
    "title": "K-School Curriculum Generation Rules",
    "version": "1.0.0",
    "released": "2026-05-31",
    "purpose": "AI 교수가 학생 프로파일과 이 원칙을 읽고 실시간으로 커리큘럼을 생성한다. 사전에 세션을 작성하지 않는다.",
    "references": [
      "IB Diploma Programme — Subject hours (HL 240h / SL 150h)",
      "IB MYP — Minimum 50h per subject per year",
      "IB PYP — Transdisciplinary themes, inquiry-based",
      "UNESCO ISCED-F 2013",
      "Piaget Developmental Stages",
      "Bloom's Taxonomy (Revised) — 6 cognitive levels"
    ]
  },

  "session_duration_by_stage": {
    "_note": "1회 학습 시간 — 연령별 집중력 한계 기반",
    "S1": { "minutes": 15, "note": "유아기 3–5세 · 놀이 단위" },
    "S2": { "minutes": 20, "note": "아동기 전기 6–8세" },
    "S3": { "minutes": 30, "note": "아동기 후기 9–11세" },
    "S4": { "minutes": 45, "note": "청소년 전기 12–14세 · IB MYP 수업 단위" },
    "S5": { "minutes": 60, "note": "청소년 후기 15–17세 · IB DP 수업 단위" },
    "S6": { "minutes": 75, "note": "대학 18–21세 · 대학 강의 단위" },
    "S7": { "minutes": 90, "note": "대학원·성인 22세+ · 세미나 단위" }
  },

  "total_hours_by_stage_and_type": {
    "_note": "과목 유형별 총 학습 시간 — IB 수업 시수 준용 + 하위 학제 비례 산정",
    "_ib_basis": "IB DP HL=240h, SL=150h, MYP=50h/year, PYP=통합 탐구",
    "S1": {
      "core":     { "hours": 30,  "duration_months": 12, "note": "주 2회 × 15분 × 12개월" },
      "optional": { "hours": 15,  "duration_months": 6  }
    },
    "S2": {
      "core":     { "hours": 60,  "duration_months": 12, "note": "주 3회 × 20분 × 12개월" },
      "optional": { "hours": 30,  "duration_months": 6  }
    },
    "S3": {
      "core":     { "hours": 90,  "duration_months": 12, "note": "주 3회 × 30분 × 12개월" },
      "optional": { "hours": 45,  "duration_months": 6  }
    },
    "S4": {
      "core":     { "hours": 150, "duration_months": 12, "note": "IB MYP 기준 200h/year의 75%" },
      "optional": { "hours": 75,  "duration_months": 6  }
    },
    "S5": {
      "HL":       { "hours": 240, "duration_months": 24, "note": "IB DP HL 기준" },
      "SL":       { "hours": 150, "duration_months": 18, "note": "IB DP SL 기준" },
      "optional": { "hours": 100, "duration_months": 12 }
    },
    "S6": {
      "major":    { "hours": 300, "duration_months": 18, "note": "3학점×16주×2학기 + 실습" },
      "elective": { "hours": 150, "duration_months": 12, "note": "3학점×16주×1학기" },
      "lab":      { "hours": 60,  "duration_months": 6,  "note": "실험·실습 단독" }
    },
    "S7": {
      "seminar":  { "hours": 90,  "duration_months": 6,  "note": "대학원 세미나" },
      "research": { "hours": 400, "duration_months": 24, "note": "연구·논문 작성" },
      "reskill":  { "hours": 60,  "duration_months": 3,  "note": "직업 재교육" }
    }
  },

  "sessions_per_week_by_stage": {
    "_note": "주당 세션 수 기본값 — 학생 요청에 따라 AI 교수가 조정",
    "S1": 2,
    "S2": 3,
    "S3": 3,
    "S4": 4,
    "S5": 4,
    "S6": 3,
    "S7": 2
  },

  "session_composition": {
    "_note": "3가지 구성 방식을 1회 세션 안에 모두 통합 적용",
    "methods": [
      {
        "id": "topic",
        "name": "토픽 단위",
        "description": "OER 교재의 챕터 또는 섹션 1개를 한 세션의 주제로 설정. 교재 순서를 따르되 학생 수준에 맞게 건너뛰거나 보충.",
        "rule": "1세션 = OER 챕터 1개 (분량이 많으면 2세션으로 분할, 적으면 2챕터 병합)"
      },
      {
        "id": "time",
        "name": "시간 단위",
        "description": "세션 시간(stage별 고정)을 3구간으로 분할하여 페이스 조절.",
        "rule": "도입(10%) + 핵심 학습(70%) + 복습·질의(20%)",
        "example_S5": "60분 = 도입 6분 + 핵심 42분 + 복습 12분"
      },
      {
        "id": "objective",
        "name": "목표 단위",
        "description": "Bloom's Taxonomy 6단계 중 해당 세션의 목표 레벨을 명시. 세션 종료 시 학생이 그 레벨에 도달했는지 확인.",
        "bloom_levels": [
          { "level": 1, "verb": "기억", "en": "Remember",  "example": "~을 말할 수 있다" },
          { "level": 2, "verb": "이해", "en": "Understand", "example": "~을 설명할 수 있다" },
          { "level": 3, "verb": "적용", "en": "Apply",      "example": "~을 풀 수 있다" },
          { "level": 4, "verb": "분석", "en": "Analyze",    "example": "~을 비교·분석할 수 있다" },
          { "level": 5, "verb": "평가", "en": "Evaluate",   "example": "~의 장단점을 판단할 수 있다" },
          { "level": 6, "verb": "창조", "en": "Create",     "example": "~을 직접 설계·작성할 수 있다" }
        ],
        "rule": "S1–S2: Bloom 1–2 위주 / S3–S4: 1–4 / S5–S6: 3–6 / S7: 5–6"
      }
    ]
  },

  "curriculum_generation_algorithm": {
    "_note": "AI 교수가 커리큘럼을 생성할 때 따르는 알고리즘",
    "steps": [
      {
        "step": 1,
        "name": "학생 프로파일 파악",
        "actions": [
          "나이 → stage(S1–S7) 결정",
          "학습 스타일 파악 (시각·청각·체험·독서형)",
          "현재 역량 파악 (해당 과목 사전 지식)",
          "취향·진로 균형점 확인"
        ]
      },
      {
        "step": 2,
        "name": "과목 유형 결정",
        "actions": [
          "S5: HL(심화) / SL(표준) 결정 → 총 시수 확정",
          "S6: 전공필수 / 선택 / 실습 결정",
          "학생 의향 우선, 진로 균형점 참고"
        ]
      },
      {
        "step": 3,
        "name": "OER 교재 선택",
        "actions": [
          "curriculum_v2.json에서 해당 과목의 oer 목록 조회",
          "학생 언어 설정에 맞는 교재 우선 선택",
          "단일 교재 또는 복수 교재 병행 결정",
          "교재의 챕터 목록을 토픽으로 변환"
        ]
      },
      {
        "step": 4,
        "name": "세션 계획 생성",
        "actions": [
          "총 시수 ÷ 1회 시간 = 총 세션 수 계산",
          "총 세션 수 ÷ 주당 세션 수 = 총 주 수 계산",
          "토픽(챕터) 수와 세션 수를 매핑",
          "각 세션에 Bloom 목표 레벨 할당",
          "복습·평가 세션을 전체의 15%로 배치"
        ]
      },
      {
        "step": 5,
        "name": "적응형 조정",
        "actions": [
          "학생이 70% 이상 이해하면 다음 세션 진행",
          "이해도 50% 미만이면 동일 토픽 다른 예시로 재설명",
          "학생 요청 시 언제든 속도·순서·깊이 조정",
          "진로 변경 요청 시 커리큘럼 전면 재생성"
        ]
      }
    ]
  },

